---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<PageLayout title="From the studio — West Michigan Art Therapy" description="Reflections on art therapy, creativity, and healing from Amy Rostollan-Hamman, ATR-BC.">
  <section class="wrap" style="padding-block:clamp(44px,6vw,76px)">
    <p class="wmat-eyebrow" style="color:var(--teal-600);margin-bottom:10px">From the studio</p>
    <h1>Notes on creativity &amp; healing</h1>

    {posts.length === 0 ? (
      <p class="wmat-lead" style="margin-top:24px">No posts yet — check back soon.</p>
    ) : (
      <div class="wmat-grid wmat-grid-3" style="gap:32px;margin-top:40px">
        {posts.map((post) => (
          <a class="wmat-post-card" href={`/blog/${post.id}/`}>
            {post.data.image && <img src={post.data.image} alt="" loading="lazy" />}
            <div class="wmat-post-body">
              <time class="wmat-post-date">{fmt(post.data.date)}</time>
              <h3 class="wmat-post-title">{post.data.title}</h3>
              {post.data.excerpt && <p class="wmat-post-excerpt">{post.data.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    )}
  </section>

  <style>
    .wmat-post-card { display: flex; flex-direction: column; text-decoration: none; color: inherit; background: var(--surface-card); border: 1px solid var(--border-soft); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-xs); transition: transform .24s var(--ease-gentle), box-shadow .24s var(--ease-gentle); }
    .wmat-post-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
    .wmat-post-card img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; }
    .wmat-post-body { padding: 20px; }
    .wmat-post-date { font-family: var(--font-body); font-size: 12px; font-weight: 600; letter-spacing: .06em; text-transform: uppercase; color: var(--teal-600); }
    .wmat-post-title { font-size: 1.375rem; margin: 8px 0 6px; }
    .wmat-post-excerpt { font-size: .9rem; line-height: 1.6; color: var(--text-muted); margin: 0; }
  </style>
</PageLayout>
