---
import PageLayout from '../layouts/PageLayout.astro';
---
<PageLayout title="Page not found — West Michigan Art Therapy" description="That page can't be found.">
  <section class="wrap" style="padding-block:clamp(64px,10vw,120px);max-width:620px;text-align:center">
    <p class="wmat-eyebrow" style="color:var(--teal-600);margin-bottom:10px">404</p>
    <h1>This page wandered off the&nbsp;shore</h1>
    <p class="wmat-lead" style="margin-top:14px">The page you're looking for isn't here. Let's get you back to solid&nbsp;ground.</p>
    <p style="margin-top:26px;display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      <a class="wmat-btn is-primary" href="/">Back home</a>
      <a class="wmat-btn is-outline" href="/contact">Contact Amy</a>
    </p>
  </section>
</PageLayout>
