---
import PageLayout from '../layouts/PageLayout.astro';
import Icon from '../components/Icon.astro';

const values = [
  { ic: 'heart-handshake', t: 'Person-centered', d: 'You set the direction. Every session follows your goals, your comfort, and your pace.' },
  { ic: 'shield-check', t: 'Safe & confidential', d: "A grounded, non-judgmental space where it's okay to not have the words yet." },
  { ic: 'sprout', t: 'Strengths-based', d: "We build on what's already within you, using creativity as a path toward growth." },
];
const regions = ['West Olive', 'Grand Rapids', 'Holland', 'Grand Haven', 'Saugatuck', 'Spring Lake'];
---
<PageLayout title="About — West Michigan Art Therapy" description="Meet Amy Rostollan-Hamman, ATR-BC — a Board-Certified Art Therapist with 15+ years of experience on Michigan's art coast.">
  <section class="wrap" style="padding-block:clamp(44px,6vw,80px);max-width:1000px">
    <div class="wmat-split is-4060">
      <div class="wmat-portrait">
        <div class="wmat-portrait-img"><img src="/assets/images/portrait-placeholder.jpg" alt="Amy Rostollan-Hamman" /></div>
        <div class="wmat-years"><b>15+</b><span>years of practice</span></div>
      </div>
      <div>
        <span class="wmat-badge">ATR-BC · Board-Certified Art Therapist</span>
        <p class="wmat-eyebrow" style="color:var(--teal-600);margin:18px 0 10px">About</p>
        <h1>Meet Amy Rostollan-Hamman</h1>
        <p class="wmat-lead" style="margin-top:14px">Amy is a Board-Certified Art Therapist with over 15 years of experience helping individuals of all ages find healing through creative expression. With a warm, person-centered approach, she guides clients facing all kinds of challenges to discover the transformative power of art therapy in their own unique journeys.</p>
        <p style="margin-top:16px;line-height:1.7;color:var(--text-muted)">She practices along Michigan's “art coast” — a region renowned for its creative spirit — and believes that healing and artistic expression belong side by side.</p>
        <p style="margin-top:26px"><a class="wmat-btn is-primary" href="/contact">Work with Amy <Icon name="arrow-right" stroke={2.2} /></a></p>
      </div>
    </div>
  </section>

  <section style="background:var(--surface-sunken);padding-block:clamp(40px,6vw,72px)">
    <div class="wrap" style="max-width:1000px">
      <div style="text-align:center;max-width:620px;margin:0 auto 36px">
        <p class="wmat-eyebrow" style="color:var(--teal-600);margin-bottom:10px">The approach</p>
        <h2>What guides our work together</h2>
      </div>
      <div class="wmat-grid wmat-grid-3" style="gap:20px">
        {values.map((v) => (
          <div class="wmat-value-card">
            <span class="wmat-chip is-sage"><Icon name={v.ic} /></span>
            <div class="wmat-card-title" style="font-size:19px;margin-top:14px">{v.t}</div>
            <p class="wmat-card-text" style="font-size:14px;color:var(--text-body)">{v.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="wrap" style="padding-block:clamp(44px,6vw,72px);max-width:900px;text-align:center">
    <p class="wmat-eyebrow" style="color:var(--teal-600);margin-bottom:10px">Where we serve</p>
    <h2>Rooted on the lakeshore</h2>
    <div class="wmat-pills" style="margin-top:22px">
      {regions.map((c) => (<span class="wmat-pill"><Icon name="map-pin" stroke={2} />{c}</span>))}
    </div>
  </section>
</PageLayout>
