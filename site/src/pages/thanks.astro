---
import PageLayout from '../layouts/PageLayout.astro';
import Icon from '../components/Icon.astro';
---
<PageLayout title="Thank you — West Michigan Art Therapy">
  <section class="wrap" style="padding-block:clamp(64px,10vw,120px);max-width:620px;text-align:center">
    <span class="wmat-chip is-sage" style="width:64px;height:64px;font-size:32px;border-radius:999px;margin:0 auto"><Icon name="check" stroke={2.4} /></span>
    <h1 style="margin-top:18px">Your note is on its way</h1>
    <p class="wmat-lead" style="margin-top:12px">Thank you for reaching out. Amy will get back to you soon — usually within a day or two.</p>
    <p style="margin-top:26px"><a class="wmat-btn is-outline" href="/">Back home</a></p>
  </section>
</PageLayout>
