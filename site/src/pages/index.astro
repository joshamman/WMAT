---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import '../styles/journey.css';
---
<BaseLayout title="West Michigan Art Therapy — Heal Through Creativity">
  <a class="skip-link" href="#top">Skip to content</a>
  <header class="j-header">
    <a class="j-logo" href="/">
      <img src="/assets/images/mark-dunes.jpg" alt="" />
      <b>West Michigan Art Therapy</b>
    </a>
    <nav class="j-nav" aria-label="Primary">
      <a class="hide-sm" href="#what">What it is</a>
      <a class="hide-sm" href="#services">Services</a>
      <a class="hide-sm" href="#amy">About&nbsp;Amy</a>
      <a class="hide-sm" href="/blog">Blog</a>
      <a class="j-cta" href="/contact">Contact</a>
    </nav>
  </header>

  <main id="top">
    <!-- HERO -->
    <section class="hero">
      <img class="hero-photo" src="/assets/images/lake_michigan_hoffmaster_beach.jpg" alt="Lake Michigan shoreline at West Olive" data-speed="0.12" />
      <div class="hero-veil"></div>
      <div class="wash drift" style="width:46vw;height:46vw;left:-10vw;top:8vh;background:radial-gradient(circle at 40% 40%, var(--teal-500), transparent 68%);opacity:.32;z-index:2" data-speed="0.05"></div>
      <div class="wash drift2" style="width:38vw;height:38vw;right:-8vw;bottom:-6vh;background:radial-gradient(circle at 50% 50%, var(--gold-400), transparent 66%);opacity:.28;z-index:2" data-speed="0.08"></div>
      <div class="hero-inner">
        <div class="dateline"><span class="j-loc">&#9678;&nbsp; West&nbsp;Olive &middot; Michigan&rsquo;s Art Coast</span></div>
        <h1>Heal through<span class="ink">creativity</span></h1>
        <p class="sub">Person-centered art therapy on the Lake&nbsp;Michigan shore, for every age, and every&nbsp;story.</p>
      </div>
      <div class="scrollcue"><span>Scroll</span><span class="line"></span></div>
    </section>

    <!-- 01 · MAKE A MARK -->
    <section class="mark" id="mark">
      <div class="wrap">
        <div class="chapter-num" data-reveal>Chapter 01 &middot; the first mark</div>
        <h2 class="display" data-reveal style="font-size:clamp(30px,5vw,64px);margin:10px 0 0">It begins with a single&nbsp;mark.</h2>
        <p data-reveal style="max-width:52ch;margin:18px auto 0;font-size:clamp(16px,1.6vw,19px);line-height:1.7;color:var(--ink-700)">There is no wrong mark to make. The first line on a blank page is not a test, and it is not a performance. It is simply a beginning, and beginnings are allowed to feel uncertain. Go ahead and make a&nbsp;mark.</p>
      </div>
      <div class="mark-stage" id="mark-stage" data-reveal aria-hidden="true">
        <canvas id="mark-canvas"></canvas>
        <div class="mark-hint" id="mark-hint">
          <span class="script">make a mark</span>
          <small>drag anywhere &middot; watch it bloom</small>
        </div>
        <button class="mark-clear" id="mark-clear" type="button" tabindex="-1">&#8635;&nbsp; Start fresh</button>
      </div>
    </section>

    <!-- 02 · WHAT IT IS -->
    <section class="what" id="what">
      <div class="wash soft drift" style="width:40vw;height:40vw;left:-12vw;top:6%;background:radial-gradient(circle, var(--sky-300), transparent 70%);opacity:.5" data-speed="0.06"></div>
      <div class="wrap" style="display:grid;gap:clamp(28px,5vw,72px);align-items:center;grid-template-columns:1.15fr .85fr">
        <div data-reveal="left">
          <div class="eyebrow-line chapter-num" style="margin-bottom:20px">Chapter 02 &middot; what art therapy is</div>
          <p class="what-quote">Have you ever made something with your hands and felt, quietly,&nbsp;<em>better?</em></p>
        </div>
        <div data-reveal>
          <p class="what-body">Art therapy is a master&rsquo;s-level mental health profession that brings together psychotherapy and the creative process within a professional, confidential therapeutic relationship. It is not arts and crafts, and it is not a recreational art&nbsp;class.</p>
          <p class="what-body" style="margin-top:18px">When words are hard to find, image-making becomes another way to express, explore, and understand what you are carrying. The focus stays on you and your goals, never on the finished piece, so what matters is the process and not the&nbsp;product.</p>
        </div>
      </div>
    </section>

    <!-- 03-06 · THE JOURNEY -->
    <section class="journey" id="journey">
      <svg class="path-svg" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        <path id="journey-path" d="M 78 2 C 30 14, 18 24, 50 36 S 86 56, 40 64 S 12 80, 60 90 S 64 98, 48 100" fill="none" stroke="var(--teal-500)" stroke-width="0.5" stroke-linecap="round" stroke-dasharray="2 2.4" vector-effect="non-scaling-stroke" opacity="0.5"/>
      </svg>
      <div class="wrap">
        <div style="text-align:center;max-width:36ch;margin:0 auto clamp(20px,4vw,40px)" data-reveal>
          <div class="chapter-num">the work, unhurried</div>
          <h2 class="display" style="font-size:clamp(30px,5vw,66px);margin:10px 0 0">The path we walk&nbsp;together</h2>
        </div>
        <div class="chapter">
          <div class="c-art" data-reveal>
            <div class="wash tear drift" style="inset:-6% -4% -6% -4%;background:radial-gradient(circle at 50% 50%, var(--teal-400), transparent 72%);opacity:.55"></div>
            <div class="frame"><img src="/assets/images/mark-landscape.jpg" alt="" style="width:100%;height:100%;object-fit:cover" /></div>
          </div>
          <div class="c-txt" data-reveal>
            <span class="chapter-num">Chapter 03</span>
            <h3>Arrive</h3>
            <p>Come exactly as you are. We take time to get comfortable with the materials and with each other, and we begin gently, with no pressure to know what comes&nbsp;next.</p>
          </div>
        </div>
        <div class="chapter flip">
          <div class="c-art" data-reveal>
            <div class="wash tear drift2" style="inset:-6% -4% -6% -4%;background:radial-gradient(circle at 50% 50%, var(--gold-400), transparent 72%);opacity:.5"></div>
            <div class="frame"><img src="/assets/images/mark-swirl.jpg" alt="" style="width:100%;height:100%;object-fit:cover" /></div>
          </div>
          <div class="c-txt" data-reveal>
            <span class="chapter-num">Chapter 04</span>
            <h3>Explore</h3>
            <p>Through color, line, and form, we make space for the feelings and experiences that are hard to say out loud, letting curiosity lead the&nbsp;way.</p>
          </div>
        </div>
        <div class="chapter">
          <div class="c-art" data-reveal>
            <div class="wash tear drift" style="inset:-6% -4% -6% -4%;background:radial-gradient(circle at 50% 50%, var(--sage-400), transparent 72%);opacity:.55"></div>
            <div class="frame"><img src="/assets/images/mark-heart.jpg" alt="" style="width:100%;height:100%;object-fit:cover" /></div>
          </div>
          <div class="c-txt" data-reveal>
            <span class="chapter-num">Chapter 05</span>
            <h3>Express</h3>
            <p>Image-making becomes a language of its own, giving shape to what has been quietly waiting to be seen and&nbsp;understood.</p>
          </div>
        </div>
        <div class="chapter flip">
          <div class="c-art" data-reveal>
            <div class="wash tear drift2" style="inset:-6% -4% -6% -4%;background:radial-gradient(circle at 50% 50%, var(--clay-400), transparent 72%);opacity:.5"></div>
            <div class="frame"><img src="/assets/images/portrait-placeholder.jpg" alt="" style="width:100%;height:100%;object-fit:cover" /></div>
          </div>
          <div class="c-txt" data-reveal>
            <span class="chapter-num">Chapter 06</span>
            <h3>Grow</h3>
            <p>Over time, the work fosters insight, self-awareness, and emotional resilience, building on the strengths that are already within&nbsp;you.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- WHO SHE HELPS -->
    <section class="what" id="who">
      <div class="wash soft drift2" style="width:42vw;height:42vw;right:-14vw;top:8%;background:radial-gradient(circle, var(--sage-400), transparent 70%);opacity:.4" data-speed="0.05"></div>
      <div class="wrap" style="max-width:920px">
        <div data-reveal style="max-width:40ch">
          <div class="chapter-num">who Amy helps</div>
          <h2 class="display" style="font-size:clamp(30px,5vw,64px);margin:10px 0 0">Care for all ages, shaped around&nbsp;you</h2>
        </div>
        <div style="display:grid;gap:clamp(20px,4vw,48px);grid-template-columns:1fr 1fr;margin-top:clamp(24px,4vw,40px)">
          <p class="what-body" data-reveal>Amy works with children, adolescents, adults, and older adults across a wide range of needs. In <strong>hospice and end-of-life care</strong>, she helps patients and families express what words alone cannot reach, find comfort and connection, and create legacy pieces that honor a life and a&nbsp;relationship.</p>
          <p class="what-body" data-reveal>With <strong>young people in the juvenile&nbsp;justice system</strong>, she offers strengths-based, trauma-informed support that builds self-confidence, self-regulation, and problem-solving through creative expression. These are settings where Amy works today, but her practice is not limited to them. Whatever you are carrying, there is a creative way&nbsp;through&nbsp;it.</p>
        </div>
      </div>
    </section>

    <!-- THE APPROACH -->
    <section class="services" id="approach">
      <div class="wrap">
        <div style="max-width:40ch" data-reveal>
          <div class="chapter-num">what guides our work together</div>
          <h2 class="display" style="font-size:clamp(30px,5vw,64px);margin:10px 0 0">The approach</h2>
        </div>
        <div class="cards-3" style="margin-top:clamp(28px,4vw,48px)">
          <div class="svc" data-reveal>
            <span class="smear" style="background:radial-gradient(circle, var(--teal-400), transparent 70%)"></span>
            <h4>Person-centered</h4>
            <p>You set the direction. Every session follows your goals, your comfort, and your own&nbsp;pace.</p>
          </div>
          <div class="svc" data-reveal>
            <span class="smear" style="background:radial-gradient(circle, var(--sage-400), transparent 70%)"></span>
            <h4>Safe &amp; confidential</h4>
            <p>A grounded, non-judgmental space where it is okay to not have the words just&nbsp;yet.</p>
          </div>
          <div class="svc" data-reveal>
            <span class="smear" style="background:radial-gradient(circle, var(--gold-400), transparent 70%)"></span>
            <h4>Strengths-based</h4>
            <p>We build on what is already within you, using creativity as a steady path toward&nbsp;growth.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SERVICES -->
    <section class="services" id="services">
      <div class="wash soft drift2" style="width:44vw;height:44vw;right:-14vw;top:10%;background:radial-gradient(circle, var(--sand-300), transparent 70%);opacity:.45" data-speed="0.05"></div>
      <div class="wrap">
        <div style="max-width:42ch" data-reveal>
          <div class="chapter-num">how we can work together</div>
          <h2 class="display" style="font-size:clamp(32px,5.4vw,72px);margin:10px 0 0">Ways&nbsp;in</h2>
          <p style="margin-top:16px;font-size:clamp(16px,1.5vw,19px);line-height:1.7;color:var(--ink-700);max-width:46ch">Every session is offered online or in person, here on the West&nbsp;Olive coast, and shaped entirely around&nbsp;you.</p>
        </div>
        <div class="svc-grid">
          <div class="svc a" data-reveal>
            <span class="smear" style="background:radial-gradient(circle, var(--teal-400), transparent 70%)"></span>
            <h4>Individual Sessions</h4>
            <p>One-on-one art therapy, 45&ndash;60 minutes, with a personalized approach, your own materials, and flexible&nbsp;scheduling.</p>
            <div class="price">$100<small>/ session</small></div>
          </div>
          <div class="svc b" data-reveal>
            <span class="tag">Most loved</span>
            <span class="smear" style="background:radial-gradient(circle, var(--gold-400), transparent 70%)"></span>
            <h4>Group Sessions</h4>
            <p>Ninety minutes of collective creativity and shared healing in a small, supportive circle, with structured, themed creative&nbsp;activities.</p>
            <div class="price">$150<small>/ session</small></div>
          </div>
          <div class="svc c" data-reveal>
            <span class="smear" style="background:radial-gradient(circle, var(--sage-400), transparent 70%)"></span>
            <h4>Workshops</h4>
            <p>Team-building and comprehensive programming, fully customized to your group&rsquo;s&nbsp;needs.</p>
            <div class="price">$200&ndash;350</div>
          </div>
          <div class="svc d" data-reveal>
            <span class="smear" style="background:radial-gradient(circle, var(--sky-400), transparent 70%)"></span>
            <h4>Online Supervision</h4>
            <p>Clinical case consultation and professional development, online or within fifteen miles of West&nbsp;Olive.</p>
            <div class="price">$75<small>/ hour</small></div>
          </div>
          <div class="svc e" data-reveal>
            <span class="smear" style="background:radial-gradient(circle, var(--clay-400), transparent 70%)"></span>
            <h4>Presentations</h4>
            <p>Customized, evidence-based content with interactive components for your&nbsp;audience.</p>
            <div class="price">$150&ndash;200</div>
          </div>
        </div>
      </div>
    </section>

    <!-- PRACTICAL: PAYMENT & FAQ -->
    <section class="what" id="practical">
      <div class="wrap" style="max-width:1000px">
        <div data-reveal style="max-width:40ch">
          <div class="chapter-num">good to know</div>
          <h2 class="display" style="font-size:clamp(30px,5vw,60px);margin:10px 0 0">Payment &amp; common&nbsp;questions</h2>
        </div>
        <div style="display:grid;gap:clamp(20px,4vw,48px);grid-template-columns:1fr 1.15fr;align-items:start;margin-top:clamp(24px,4vw,40px)">
          <div style="display:flex;flex-direction:column;gap:14px" data-reveal>
            <div class="wmat-callout is-note">
              <span class="wmat-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/></svg></span>
              <div><span class="wmat-callout-title">Sliding scale available</span><span class="wmat-callout-body">Flexible pricing is offered for individual sessions &mdash; just&nbsp;ask.</span></div>
            </div>
            <div class="wmat-callout is-info">
              <span class="wmat-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg></span>
              <div><span class="wmat-callout-title">Payment &amp; insurance</span><span class="wmat-callout-body">Cash, check, and PayPal are welcome. Insurance is not currently accepted; location and materials may affect final&nbsp;pricing.</span></div>
            </div>
          </div>
          <div class="wmat-faq" data-reveal>
            <details open>
              <summary>Are sessions virtual or in&nbsp;person?</summary>
              <div class="wmat-faq-body">Both. Sessions are offered online or in person, here on the West&nbsp;Olive coast, and shaped around your&nbsp;needs.</div>
            </details>
            <details>
              <summary>Who do you work&nbsp;with?</summary>
              <div class="wmat-faq-body">Children, adolescents, adults, and older adults, across many settings and a wide range of needs. You are welcome&nbsp;here.</div>
            </details>
          </div>
        </div>
      </div>
    </section>

    <!-- AMY -->
    <section class="amy" id="amy">
      <div class="wash soft drift" style="width:38vw;height:38vw;left:-12vw;bottom:-8%;background:radial-gradient(circle, var(--teal-400), transparent 70%);opacity:.4" data-speed="0.05"></div>
      <div class="wrap amy-grid">
        <div class="amy-portrait" data-reveal="left">
          <div class="wash tear drift2" style="inset:-7%;background:radial-gradient(circle at 50% 50%, var(--gold-300), transparent 72%);opacity:.55;z-index:0"></div>
          <img src="/assets/images/amy-pittsburgh.jpg" alt="Amy Rostollan-Hamman, ATR-BC" style="position:relative;z-index:2;width:100%;aspect-ratio:4/5;object-fit:cover;object-position:5% 20%;border-radius:20px;display:block" />
          <div class="badge"><b>15+</b><span>years of practice</span></div>
        </div>
        <div data-reveal>
          <div class="chapter-num">the person across the table</div>
          <h2>Meet Amy&nbsp;Rostollan-Hamman, <span class="serif-italic" style="color:var(--teal-600)">ATR-BC</span></h2>
          <p>Amy is a Board&nbsp;Certified Registered Art Therapist (ATR-BC) with more than fifteen years of experience. The ATR-BC is the highest level of professional distinction granted by the Art Therapy Credentials Board, earned through master&rsquo;s-level education, supervised clinical experience, and a national board certification&nbsp;exam.</p>
          <p style="margin-top:16px">She believes healing and artistic expression belong side by side, and she brings a warm, grounded presence to every relationship. When you are ready, she would be glad to work with&nbsp;you.</p>
          <a class="btn-paint gold" href="/contact" style="margin-top:26px">Work with Amy &rarr;</a>
        </div>
      </div>
    </section>

    <!-- WHERE WE SERVE -->
    <section class="services" id="serve" style="padding-top:0">
      <div class="wrap" style="text-align:center;max-width:820px">
        <div data-reveal>
          <div class="chapter-num">where we serve</div>
          <h2 class="display" style="font-size:clamp(28px,4.6vw,56px);margin:10px 0 0">Rooted on the&nbsp;lakeshore</h2>
          <p style="margin:16px auto 0;font-size:clamp(15px,1.4vw,18px);line-height:1.7;color:var(--ink-700);max-width:52ch">Based in West&nbsp;Olive and serving the surrounding lakeshore. In-person across these areas, and online wherever you&nbsp;are.</p>
        </div>
        <div class="wmat-pills" style="margin-top:24px" data-reveal>
          <span class="wmat-pill">West&nbsp;Olive</span>
          <span class="wmat-pill">Grand&nbsp;Rapids</span>
          <span class="wmat-pill">Holland</span>
          <span class="wmat-pill">Grand&nbsp;Haven</span>
          <span class="wmat-pill">Saugatuck</span>
          <span class="wmat-pill">Spring&nbsp;Lake</span>
        </div>
      </div>
    </section>

    <!-- CLOSING (dusk) -->
    <section class="closing" id="begin">
      <img class="hero-photo" src="/assets/images/lake_michigan_hoffmaster_beach.jpg" alt="" data-speed="0.1" style="height:130%;top:-15%;opacity:.34;filter:saturate(.7) brightness(.7)" />
      <div class="wash drift" style="width:52vw;height:52vw;left:50%;top:0;transform:translateX(-50%);background:radial-gradient(circle, var(--gold-400), transparent 64%);opacity:.4;z-index:1" data-speed="0.06"></div>
      <div class="wrap" style="position:relative;z-index:3;padding-bottom:clamp(70px,12vw,150px)">
        <div class="dateline" style="color:var(--gold-300);margin-bottom:20px" data-reveal>&#9678;&nbsp; West&nbsp;Olive, Michigan</div>
        <h2 data-reveal>Begin where<span class="ink">you are.</span></h2>
        <p class="sub" data-reveal>Not sure where to start? That is completely normal. Send a note and we will find the right kind of session together, at a pace that feels right to&nbsp;you.</p>
        <div class="btn-row" data-reveal>
          <a class="btn-paint gold" href="/contact">&#9993;&nbsp; Get in touch</a>
          <a class="btn-paint ghost" href="#services">See the services</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="site-footer-in">
      <div class="site-footer-brand">
        <a class="j-logo" href="/" style="gap:11px">
          <img src="/assets/images/mark-dunes.jpg" alt="" style="width:38px;height:38px;border-radius:11px;object-fit:cover" />
          <span style="display:flex;flex-direction:column;line-height:1.2">
            <b style="font-family:var(--font-display);font-size:18px;color:var(--cream-50)">West Michigan Art Therapy</b>
            <span class="muted">Amy Rostollan-Hamman, ATR-BC</span>
          </span>
        </a>
        <p class="muted" style="margin:14px 0 0;max-width:34ch;font-size:14px;line-height:1.6">Person-centered art therapy for all ages on Michigan&rsquo;s art coast &mdash; in&nbsp;person and&nbsp;online.</p>
      </div>
      <div class="site-footer-col">
        <p class="site-foot-label">Explore</p>
        <a href="#services">Services</a>
        <a href="#amy">About&nbsp;Amy</a>
        <a href="/blog">Blog</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="site-footer-col">
        <p class="site-foot-label">Reach Amy</p>
        <a href="mailto:amy@westmichiganarttherapy.com">amy@westmichiganarttherapy.com</a>
        <span class="muted">West Olive, Michigan</span>
        <span class="site-footer-social">
          <a href="https://www.facebook.com/WestMichiganArtTherapy" aria-label="West Michigan Art Therapy on Facebook" target="_blank" rel="noopener"><Icon name="facebook" /></a>
          <a href="https://www.linkedin.com/in/amy-rostollan-hamman-b386ba86/" aria-label="Amy Rostollan-Hamman on LinkedIn" target="_blank" rel="noopener"><Icon name="linkedin" /></a>
        </span>
      </div>
      <div class="site-footer-col">
        <p class="site-foot-label">Professional affiliations</p>
        <a href="https://arttherapy.org/" target="_blank" rel="noopener">American Art Therapy Association</a>
        <a href="https://www.michiganarttherapy.org/" target="_blank" rel="noopener">Michigan Association of Art Therapy</a>
        <a href="https://www.atcb.org/" target="_blank" rel="noopener">Art Therapy Credentials Board</a>
      </div>
    </div>
    <div class="site-footer-bar">
      <span>&copy; {new Date().getFullYear()} West Michigan Art Therapy &middot; Amy Rostollan-Hamman, ATR-BC</span>
      <span class="loc">&#9678;&nbsp; West Olive, Michigan</span>
    </div>
  </footer>

  <script src="/assets/js/journey.js" is:inline></script>
</BaseLayout>
